# EarnForge Production Environment
# Copy to .env (or set in Vercel/ hosting platform) and fill real values BEFORE deploying

# Postgres (recommended for production). Create free DB at Supabase or Neon.
# Example: postgresql://user:password@host:5432/earnforge?sslmode=require
DATABASE_URL="postgresql://CHANGE_ME"

# === Stripe (LIVE keys for real money) ===
# 1. https://dashboard.stripe.com/apikeys (switch from Test to Live)
# 2. Create a Product for Pro ($9.99/mo recurring) - copy the Price ID if you want to use it instead of dynamic
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
# IMPORTANT: Create webhook endpoint in Stripe dashboard pointing to https://yourdomain.com/api/stripe/webhook
# Select event: checkout.session.completed
# Copy the "Signing secret" (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# === Auth ===
# Generate with: $bytes = New-Object byte[] 64; [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($bytes); [Convert]::ToBase64String($bytes)
JWT_SECRET=VERY_LONG_RANDOM_BASE64_STRING_HERE_MIN_64_BYTES

# Your production URL (after Vercel deploy or custom domain)
NEXT_PUBLIC_APP_URL=https://earnforge.app   # or your vercel app url

# Bootstrap admin (create this user once, then delete or change password via DB/admin UI)
# Use a very strong password. After first login as admin, you can remove this or set a flag.
ADMIN_BOOTSTRAP_EMAIL=admin@yourdomain.com
ADMIN_BOOTSTRAP_PASSWORD=SuperStrongRandomPass123!ChangeMeImmediately

# Optional (add when you implement)
# RESEND_API_KEY=re_...
# OPENAI_API_KEY=sk-...   # for AI task generation later

# Production notes:
# - After first deploy + admin login, seed real tasks via the admin UI
# - Test Pro checkout and campaign funding end-to-end with live Stripe (use small amounts first)
# - Set up monitoring / error logging (Sentry, etc.) before heavy traffic